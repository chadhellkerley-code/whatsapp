# Application environment variables
NODE_ENV=production
PORT=3000
DATABASE_URL=mysql://user:password@host:3306/database
JWT_SECRET=your-jwt-secret

# Manus OAuth and API integration
VITE_APP_ID=your-manus-app-id
OAUTH_SERVER_URL=https://your-manus-oauth-server.com
VITE_OAUTH_PORTAL_URL=https://your-manus-portal.com
OWNER_OPEN_ID=owner-open-id
OWNER_NAME=owner-name
BUILT_IN_FORGE_API_URL=https://your-manus-built-in-api.com
BUILT_IN_FORGE_API_KEY=your-built-in-api-key
VITE_FRONTEND_FORGE_API_URL=https://your-manus-built-in-api.com
VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-api-key

# Optional override when the frontend is deployed separately from the backend
VITE_API_URL=https://api.your-domain.com/api/trpc
